# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/frontend/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!backend/.env.example
!frontend/.env.example

# backend env file (keep secrets local)
backend/.env
frontend/.env.local

# backend local/runtime artifacts
backend/venv/
backend/uploads/
backend/static/plots/
backend/__pycache__/
backend/.pytest_cache/

# python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# editor files
.idea/
.vscode/

# runtime logs
*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
